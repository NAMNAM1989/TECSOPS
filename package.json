{
  "name": "air-cargo-tracking",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:concurrent": "concurrently -k -n srv,vite -c blue,green \"node server/index.mjs\" \"vite\"",
    "setup:ecargo": "npx playwright install chromium",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "ci": "npm run lint && npm run build && npm test && npm run deploy:check",
    "test": "vitest run",
    "sample:day-report": "tsx scripts/generate-sample-day-report.ts",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "start:railway": "node scripts/check-deploy-safe.mjs && node server/index.mjs",
    "deploy:check": "node scripts/check-deploy-safe.mjs",
    "deploy:safe": "node scripts/deploy-safe-preflight.mjs",
    "deploy:ship": "node scripts/deploy-ship.mjs",
    "backup:redis-state": "node scripts/redis-backup-state.mjs",
    "restore:redis-state": "node scripts/redis-restore-state.mjs",
    "migrate:postgres-state": "node scripts/postgres-migrate-state.mjs",
    "migrate:postgres-catalog": "node scripts/postgres-migrate-master-catalog.mjs",
    "migrate:customer-relations": "node scripts/migrate-customer-relations.mjs",
    "migrate:print-templates": "node scripts/migrate-print-templates.mjs",
    "backup:postgres-state": "node scripts/postgres-backup-state.mjs",
    "restore:postgres-state": "node scripts/postgres-restore-state.mjs",
    "import:scsc-template": "node scripts/import-scsc-template.mjs",
    "railway:up": "node scripts/railway-up.mjs"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "imapflow": "^1.0.186",
    "konva": "^9.3.22",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "use-image": "^1.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "pdf-to-img": "^6.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
