# Bản sao môi trường — không đưa giá trị thật vào git. Railway: Service → Variables.

# Cổng HTTP (Railway tự inject; local có thể bỏ trống → mặc định 3001 trong code)
# PORT=3001

# production | development (build Vite thường set production)
# NODE_ENV=production

# Mật khẩu truy cập trang (tùy chọn). **Bắt buộc có giá trị** thì trang mới hiện ô nhập mật khẩu (GET /api/auth/gate → { "required": true }).
# Đăng nhập qua POST /api/login (cookie httpOnly). GET /api/health không cần cookie (Railway healthcheck).
# TECSOPS_ACCESS_PASSWORD=your-strong-password
# Tuỳ chọn: chuỗi bí mật ký cookie (mặc định suy ra từ mật khẩu nếu bỏ trống).
# TECSOPS_SESSION_SECRET=random-long-string

# Postgres production — nguồn dữ liệu chính sau khi migrate Redis → Railway Postgres.
# App lưu nguyên state `{ version, rows, customers }` vào bảng `app_state` dạng JSONB.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB
# POSTGRES_STATE_KEY=tecsops:state

# Redis tùy chọn — dùng trong giai đoạn migrate/rollback và Socket.IO adapter nếu scale >1 replica.
# REDIS_URL=redis://default:PASSWORD@HOST:PORT

# Thư mục lưu state.json khi không dùng Redis (mặc định: server/data)
# DATA_DIR=/data

# Khóa Redis tùy biến (mặc định: tecsops:state)
# REDIS_STATE_KEY=tecsops:state
# REDIS_LOCK_KEY=tecsops:state-lock

# In TSPL qua mạng: danh sách IP máy in được phép (rỗng = tắt in TCP)
# TSPL_ALLOWED_HOSTS=192.168.1.50,10.0.0.5

# CORS Socket.IO: danh sách origin được phép, cách nhau bởi dấu phẩy.
# Production: nếu để trống → chỉ same-origin. Dev (Vite proxy) thường không cần set.
# CORS_ORIGINS=https://your-app.up.railway.app

# Sau khi `npm run deploy:ship` push xong, script **poll** GET …/api/health cho đến HTTP 200 (mặc định tối đa ~15 phút, mỗi 10s).
# TECSOPS_VERIFY_URL=https://your-app.up.railway.app
# TECSOPS_VERIFY_WAIT_MS=900000
# TECSOPS_VERIFY_INTERVAL_MS=10000

# Khi `git push` báo "Everything up-to-date", Railway/GitHub có thể không build lại. Cách 1: Deploy Hook (Railway → Service → Settings → Deploy → Webhook).
# RAILWAY_DEPLOY_HOOK_URL=https://api.railway.app/...
# Cách 2 (mặc định nếu không có hook): script tạo empty commit + push. Để tắt hành vi này: TECSOPS_NO_EMPTY_REDEPLOY=1
