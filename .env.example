# Bản sao môi trường — không đưa giá trị thật vào git. Railway: Service → Variables.

# Cổng HTTP (Railway tự inject; local có thể bỏ trống → mặc định 3001 trong code)
# PORT=3001

# production | development (build Vite thường set production)
# NODE_ENV=production

# Postgres — BẮT BUỘC. Nguồn dữ liệu chính (bảng app_state, cột state jsonb).
# Local: docker compose up -d  →  port 5434
# DATABASE_URL=postgresql://tecsops:tecsops@127.0.0.1:5434/tecsops
# POSTGRES_STATE_KEY=tecsops:state

# Google Sheet BOOK HẰNG NGÀY — nhập lô từ tab DDMONTHYYYY (vd. 13JUNE2026)
# GOOGLE_SHEETS_BOOK_SPREADSHEET_ID=15EHqZuuYznL2_VkCnpENHgc_mmBTSJGgrNG3iv5ZvA4

# Dev: cổng API khi proxy Vite (mặc định 3001, trùng server)
# VITE_PROXY_PORT=3001

# CORS Socket.IO: danh sách origin được phép, cách nhau bởi dấu phẩy.
# Production: nếu để trống → chỉ same-origin. Dev (Vite proxy) thường không cần set.
# CORS_ORIGINS=https://your-app.up.railway.app

# Sau khi `npm run deploy:ship` push xong, script poll GET …/api/health.
# TECSOPS_VERIFY_URL=https://your-app.up.railway.app
# TECSOPS_VERIFY_WAIT_MS=900000
# TECSOPS_VERIFY_INTERVAL_MS=10000

# Railway CLI — PROJECT TOKEN (đặt trong .env.local, KHÔNG commit).
# Railway Dashboard → project → Project Settings → Tokens → Create
# RAILWAY_TOKEN=

# Khi git push báo "Everything up-to-date": Deploy Hook hoặc empty commit redeploy.
# RAILWAY_DEPLOY_HOOK_URL=https://api.railway.app/...
# TECSOPS_NO_EMPTY_REDEPLOY=1
