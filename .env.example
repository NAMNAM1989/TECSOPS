# Bản sao môi trường — không đưa giá trị thật vào git. Railway: Service → Variables.

# Cổng HTTP (Railway tự inject; local có thể bỏ trống → mặc định 3001 trong code)
# PORT=3001

# production | development (build Vite thường set production)
# NODE_ENV=production

# Redis tùy chọn — bắt buộc nếu scale >1 replica hoặc cần state dùng chung
# REDIS_URL=redis://default:PASSWORD@HOST:PORT

# Thư mục lưu state.json khi không dùng Redis (mặc định: server/data)
# DATA_DIR=/data

# Khóa Redis tùy biến (mặc định: tecsops:state)
# REDIS_STATE_KEY=tecsops:state
# REDIS_LOCK_KEY=tecsops:state-lock

# In TSPL qua mạng: danh sách IP máy in được phép (rỗng = tắt in TCP)
# TSPL_ALLOWED_HOSTS=192.168.1.50,10.0.0.5

# CORS Socket.IO: danh sách origin được phép, cách nhau bởi dấu phẩy.
# Production: nếu để trống → chỉ same-origin. Dev (Vite proxy) thường không cần set.
# CORS_ORIGINS=https://your-app.up.railway.app
