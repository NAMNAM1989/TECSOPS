# Copy thành .env (đã gitignore) — không commit mật khẩu.
TCS_BASE_URL=https://www.tcs.com.vn/AwbLogin
TCS_AGENT_HOST=127.0.0.1
TCS_AGENT_PORT=8765
TCS_MOCK=0
TCS_DRY_RUN=0
TCS_OUTPUT_DIR=./output
TCS_BROWSER_PROFILE=./browser_profile
TCS_MIN_DELAY_MS=800
TCS_MAX_DELAY_MS=1800
TCS_WAREHOUSE_SCOPE=TECS-TCS

# Đăng nhập: tự điền user/pass từ đây.
TCS_USERNAME=
TCS_PASSWORD=

# Cách 1 — ưu tiên cookie/profile đã login (không hỏi CAPTCHA nếu còn phiên).
TCS_PREFER_SESSION=1

# Cách 2 — OCR CAPTCHA local (ddddocr). Tắt = 0 nếu muốn nhập tay.
TCS_CAPTCHA_OCR=1
TCS_CAPTCHA_OCR_ATTEMPTS=3
TCS_CAPTCHA_MANUAL_TIMEOUT_S=180
