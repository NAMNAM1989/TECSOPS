{
  "name": "air-cargo-tracking",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:db": "docker compose up -d",
    "tcs:agent": "node scripts/tcs-agent.mjs",
    "tcs:agent:real": "node scripts/tcs-agent.mjs --real",
    "qa:smoke": "node scripts/qa-smoke-e2e.mjs",
    "ext:verify": "node chrome-extension/scripts/cdp-load-and-verify.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint src",
    "lint:server": "eslint server",
    "ci": "npm run lint && npm run lint:server && npm run build && npm test && npm run deploy:check",
    "test": "vitest run",
    "sample:day-report": "tsx scripts/generate-sample-day-report.ts",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "start:railway": "node scripts/check-deploy-safe.mjs && node server/index.mjs",
    "deploy:check": "node scripts/check-deploy-safe.mjs",
    "deploy:safe": "node scripts/deploy-safe-preflight.mjs",
    "deploy:ship": "node scripts/deploy-ship.mjs",
    "migrate:postgres-state": "node scripts/postgres-migrate-state.mjs",
    "migrate:postgres-catalog": "node scripts/postgres-migrate-master-catalog.mjs",
    "migrate:customer-relations": "node scripts/migrate-customer-relations.mjs",
    "backup:postgres-state": "node scripts/postgres-backup-state.mjs",
    "restore:postgres-state": "node scripts/postgres-restore-state.mjs",
    "railway:check": "node scripts/railway-check-token.mjs",
    "railway:up": "node scripts/railway-up.mjs"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "http-proxy": "^1.18.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
