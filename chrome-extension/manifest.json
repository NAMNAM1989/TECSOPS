{
  "manifest_version": 3,
  "name": "TECSOPS — Điền ESID TCS",
  "version": "2.0.6",
  "description": "TCS workspace trực quan: Login, quét theo ngày và điền ESID trên một tab Chrome được ghim.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://www.tcs.com.vn/*",
    "https://tcs.com.vn/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "https://ops-production-b405.up.railway.app/*",
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TECSOPS · Điền ESID",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:4173/*",
        "http://127.0.0.1:4173/*",
        "https://ops-production-b405.up.railway.app/*",
        "https://*.up.railway.app/*"
      ],
      "js": ["content-ops.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.tcs.com.vn/*", "https://tcs.com.vn/*"],
      "js": ["content-tcs.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["locators.json"],
      "matches": ["https://www.tcs.com.vn/*", "https://tcs.com.vn/*"]
    }
  ]
}
