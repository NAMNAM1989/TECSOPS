{
  "name": "air-cargo-tracking",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n srv,vite -c blue,green \"node server/index.mjs\" \"vite\"",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "sample:day-report": "tsx scripts/generate-sample-day-report.ts",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "start:railway": "node scripts/check-deploy-safe.mjs && node server/index.mjs",
    "deploy:check": "node scripts/check-deploy-safe.mjs",
    "backup:redis-state": "node scripts/redis-backup-state.mjs",
    "restore:redis-state": "node scripts/redis-restore-state.mjs"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
